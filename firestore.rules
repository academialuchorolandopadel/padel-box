rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function logueado() { return request.auth != null; }
    function esStaff() {
      return logueado() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }
    function esAdmin() {
      return esStaff() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // Cada empleado habilitado tiene un doc en /usuarios/{uid} con { nombre, rol: 'cajero' | 'admin' }
    match /usuarios/{uid} {
      allow read: if logueado() && (request.auth.uid == uid || esAdmin());
      allow write: if esAdmin();
    }

    // Precios (doc único config/precios) — solo el admin los cambia
    match /config/{docId} {
      allow read: if esStaff();
      allow write: if esAdmin();
    }

    match /clientes/{id} {
      allow read, create, update: if esStaff();
      allow delete: if esAdmin();
    }

    match /productos/{id} {
      allow read, update: if esStaff();   // el cajero repone stock y vende
      allow create, delete: if esAdmin(); // alta/baja de productos: admin
    }

    match /turnos/{id} {
      allow read, write: if esStaff();
    }

    match /cuentas/{id} {
      allow read, create, update, delete: if esStaff();
    }

    match /fijos/{id} {
      allow read, create, update: if esStaff();
      allow delete: if esAdmin();
    }

    match /gastos/{id} {
      allow read, create: if esStaff();
      allow delete: if esAdmin();
    }
  }
}
